APP_ENV=production
DATA_DIR=/data/projects
PUBLIC_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
JSON_LOGS=true
FFMPEG_BIN=ffmpeg

DEFAULT_RENDER_WIDTH=1920
DEFAULT_RENDER_HEIGHT=1080
DEFAULT_RENDER_FPS=30

PROJECT_STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://ai_video_studio:ai_video_studio_change_me@postgres:5432/ai_video_studio
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_AUTO_MIGRATE=true
AUDIT_STORAGE_BACKEND=postgres
SUPPORT_STORAGE_BACKEND=postgres
IDEMPOTENCY_STORAGE_BACKEND=postgres
USAGE_STORAGE_BACKEND=postgres

ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_URL_TTL_SECONDS=3600
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=ai-video-studio
S3_PUBLIC_BASE_URL=

ENABLE_BROWSER_SCREENSHOTS=false
BROWSER_SCREENSHOT_TIMEOUT_MS=12000

DEFAULT_SCRIPT_PROVIDER=template
DEFAULT_VOICE_PROVIDER=placeholder
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.55
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
MAX_OPENAI_TTS_CHARS=3800
BURN_SUBTITLES_BY_DEFAULT=false

RUN_JOBS_INLINE=false
EXECUTE_JOBS_IN_API=false
JOB_WORKERS=2
JOB_STORAGE_BACKEND=postgres
RENDER_TIMEOUT_SECONDS=1800

# Required for private production routes. Generate a long random value and keep it secret.
# Example PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | ForEach-Object {[char]$_})
API_KEY=
ENABLE_USER_AUTH=false
ACCESS_TOKEN_TTL_MINUTES=1440
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_ALGORITHMS=RS256
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
RATE_LIMIT_REQUESTS_PER_MINUTE=120
MAX_REQUEST_BODY_BYTES=2000000
CORS_ORIGINS=http://localhost:19006,http://localhost:8081

ALLOW_UNSAFE_HTTP_SOURCES=false
ALLOW_PRIVATE_SOURCE_URLS=false
CLEANUP_RETENTION_DAYS=14

STRIPE_API_KEY=
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:19006/billing/success
STRIPE_CANCEL_URL=http://localhost:19006/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:19006/billing
BILLING_PRO_MAX_PROJECTS=250
BILLING_PRO_MAX_ACTIVE_JOBS=10
