# local/test/dev/development allow running without API_KEY.
# Any other value is treated as non-local and requires API_KEY for private routes.
APP_ENV=local
DATA_DIR=./data/projects
PUBLIC_BASE_URL=http://localhost:8000
# Если FFMPEG_BIN не найден в PATH, backend попробует bundled fallback
# из imageio-ffmpeg.
FFMPEG_BIN=ffmpeg
DEFAULT_RENDER_WIDTH=1920
DEFAULT_RENDER_HEIGHT=1080
DEFAULT_RENDER_FPS=30

# По умолчанию MVP работает офлайн и рисует fallback-карточки источников.
# Для реальных скриншотов сайтов установите Playwright и включите флаг:
# pip install playwright && playwright install chromium
ENABLE_BROWSER_SCREENSHOTS=false
BROWSER_SCREENSHOT_TIMEOUT_MS=12000

# v0.3 provider layer. Без ключа всё работает через template/placeholder fallback.
DEFAULT_SCRIPT_PROVIDER=template
DEFAULT_VOICE_PROVIDER=placeholder
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.55
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
MAX_OPENAI_TTS_CHARS=3800
BURN_SUBTITLES_BY_DEFAULT=false

# v0.4 local job queue. Для production заменить на Redis/BullMQ/Celery/Temporal.
RUN_JOBS_INLINE=false
JOB_WORKERS=2

# Security / API surface.
# Если API_KEY задан, все endpoints кроме /health, /ready, /providers и docs требуют X-API-Key.
# Для APP_ENV=production или другого non-local значения API_KEY обязателен.
API_KEY=
# 0 отключает встроенный in-memory limiter. Для production лучше ставить лимит и/или внешний API Gateway.
RATE_LIMIT_REQUESTS_PER_MINUTE=0
CORS_ORIGINS=http://localhost:19006,http://localhost:8081

# Source URL safety. По умолчанию реальные screenshot URLs не могут указывать
# на localhost/private networks и plain HTTP.
ALLOW_UNSAFE_HTTP_SOURCES=false
ALLOW_PRIVATE_SOURCE_URLS=false

# Локальная очистка старых completed/failed проектов и job-файлов.
CLEANUP_RETENTION_DAYS=14
